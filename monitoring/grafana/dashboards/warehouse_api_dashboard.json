{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Prediction Requests Total",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "prediction_requests_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prediction Errors Total",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "prediction_request_errors_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Incident Events Total",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "incident_events_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prediction Latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mlops", "warehouse", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Warehouse API Monitoring",
  "version": 1
}
